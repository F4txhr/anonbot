# Required
BOT_TOKEN=your_telegram_bot_token_here

# Database
DATABASE_URL=postgresql://anonbot:changeme@postgres:5432/anonbot?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Telegram Payments (obtain from @BotFather)
TELEGRAM_BOT_USERNAME=your_bot_username
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token

# VIP Configuration
VIP_PRICE_STARS=25
VIP_DURATION_DAYS=7

# Matching Configuration
FREE_MATCH_COOLDOWN_SECONDS=30
VIP_MATCH_COOLDOWN_SECONDS=0

# Rate Limiting
MESSAGE_RATE_LIMIT=10
MESSAGE_RATE_WINDOW_SECONDS=60

# Trust Score
INITIAL_TRUST_SCORE=100
MIN_TRUST_SCORE=0
MAX_TRUST_SCORE=100

# Referral
REFERRAL_VIP_HOURS=12

# Admin
ADMIN_USER_IDS=123456789,987654321

# Security
SESSION_SECRET=change_me_in_production_min_32_chars

# Feature Flags
ENABLE_REFERRALS=true
ENABLE_PAYMENTS=true